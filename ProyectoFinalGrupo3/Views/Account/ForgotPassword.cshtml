@model ProyectoFinalGrupo3.Models.ViewModel.ForgotPasswordViewModel
@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "Recuperar Contraseña";
}
<partial name="Partials/_ModalForgotExitoso" model="Model" />
<partial name="Partials/_ModalForgotFallo" model="Model" />

<div class="w-full flex items-center justify-center p-4 min-h-[calc(100vh-4rem)]">
    <div class="w-full max-w-md bg-background-light dark:bg-background-dark/90 backdrop-blur-md rounded-xl shadow-2xl overflow-hidden border border-primary/20">
        <div class="px-8 pt-10 pb-6 flex flex-col items-center">
            <div class="mb-6 flex items-center gap-3">
                <div class="bg-primary p-2 rounded-lg text-white">
                    <span class="material-symbols-outlined text-3xl">restaurant</span>
                </div>
                <h1 class="text-3xl font-black tracking-tighter text-slate-900 dark:text-white uppercase">Atelier 27</h1>
            </div>
            <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-slate-100 mb-2">¿Olvidó su contraseña?</h2>
                <p class="text-slate-600 dark:text-primary/70 text-sm">
                    Ingrese su correo electrónico para recibir las instrucciones de recuperación.
                </p>
            </div>
            <form asp-action="ForgotPassword" asp-controller="Account" method="post" class="w-full space-y-6">
                <div asp-validation-summary="All" class="text-red-500 mb-4"></div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" for="email">Correo electrónico</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-primary/60">mail</span>
                        <input asp-for="Correo"
                               class="w-full pl-10 pr-4 py-3 bg-white dark:bg-background-dark/50 border border-slate-300 dark:border-primary/30 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all dark:text-white dark:placeholder-slate-500"
                               placeholder="ejemplo@atelier27.com" type="email" />
                    </div>
                    <span asp-validation-for="Correo" class="text-red-500 text-sm"></span>
                </div>

                <button type="submit"
                        class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-4 rounded-lg transition-colors flex items-center justify-center gap-2 group shadow-lg shadow-primary/20">
                    <span>Enviar instrucciones</span>
                    <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">send</span>
                </button>
            </form>
            <div class="mt-8 text-center">
                <a onclick="document.location.href='@Url.Content("~/Account/Login/")'" class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary/80 transition-colors" href="#">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    Volver al inicio de sesión
                </a>
            </div>
        </div>
        <div class="px-8 py-4 bg-slate-100 dark:bg-primary/10 border-t border-slate-200 dark:border-primary/20 flex justify-center">
            <p class="text-[10px] text-slate-500 dark:text-primary/40 uppercase tracking-widest font-bold">Experiencia Gastronómica Exclusiva</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal(id) {
            document.getElementById(id).classList.add("hidden");
        }

        window.onload = function() {
            var success = '@ViewBag.ForgotSuccess';
            if (success === 'True') {
                document.getElementById("forgotSuccessModal").classList.remove("hidden");
                setTimeout(function() {
                    window.location.href = '@Url.Action("ResetPassword", "Account")';
                }, 3000);
            } else if (success === 'False') {
                document.getElementById("forgotFailModal").classList.remove("hidden");
            }
        }
    </script>
}