@model ProyectoFinalGrupo3.Models.ViewModel.LoginViewModel
@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "Login";
}
<partial name="Partials/_ModalExitoso" model="Model" />
<partial name="Partials/_ModalFallo" model="Model" />

<div class="flex min-h-screen">
    <!-- Left Side: Hero Image -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center" data-alt="Luxurious dimly lit fine dining room interior" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDJAxc_v5j41iU_ecB2OA9S5brbGSe4vaEJNui0cwOga2ghpZytVTMgzZwBcxdc-ljmUtv5sIogwNn-2VtNbRrMHOgTrl9kKYMIgBT_9jj52kweYod9bTOUonxPJqw9kFnlkLZN26GSz_DG6xL6GcrU8fUW-1KrHReytk4ViisJqbWIiB0MLW9OxhnywNtILbpVDTEry0vUTOAbL8-U9v9_sQDkK5DkUtPu-9xW0g3mcTQW_BXgiWsxo8gTY-E7BS2EBTNzAp4bGq_Z");'></div>
        <div class="absolute inset-0 bg-background-dark/40 backdrop-blur-[2px]"></div>
        <div class="relative z-10 flex flex-col justify-between p-12 w-full">
            <div class="flex items-center gap-3 text-primary">
                <span class="material-symbols-outlined text-4xl">restaurant</span>
                <h1 class="text-2xl font-bold tracking-widest uppercase">Atelier 27</h1>
            </div>
            <div>
                <h2 class="text-5xl font-light leading-tight text-white mb-6">Experimenta el <br /><span class="text-primary italic">arte de la fusión</span></h2>
                <p class="text-slate-200 text-lg max-w-md">Únase a nuestro círculo exclusivo para un viaje culinario que trasciende fronteras.</p>
            </div>
            <div class="text-slate-400 text-sm">© 2024 Atelier 27 Culinary Group.</div>
        </div>
    </div>
    <!-- Right Side: Login Form -->
    <div class="flex-1 flex flex-col justify-center items-center px-6 py-12 lg:px-24 bg-background-light dark:bg-background-dark">
        <div class="w-full max-w-md">
            <!-- Mobile Logo -->
            <div class="lg:hidden flex flex-col items-center mb-10">
                <span class="material-symbols-outlined text-5xl text-primary mb-2">restaurant</span>
                <h1 class="text-3xl font-bold tracking-widest uppercase text-slate-900 dark:text-slate-100">Atelier 27</h1>
            </div>

            <div class="mb-10 text-center lg:text-left">
                <h2 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-2">Bienvenido de nuevo</h2>
                <p class="text-slate-600 dark:text-slate-400">Por favor, introduzca sus datos para acceder a sus reservas.</p>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" class="space-y-6">
                <div>
                    <label>Correo Electrónico</label>
                    <input asp-for="Correo" type="email"
                           class="form-input w-full rounded-lg border-slate-300 dark:border-primary/30"
                           style="color:black" />
                </div>

                <div>
                    <label>Contraseña</label>
                    <input asp-for="Contrasena" type="password"
                           class="form-input w-full rounded-lg border-slate-300 dark:border-primary/30"
                           style="color:black" />
                </div>

                <button type="submit" class="w-full bg-primary text-white font-bold py-3 px-4 rounded-lg">
                    Iniciar Sesión
                </button>
            </form>
        </div>

        <p class="mt-10 text-center text-sm text-slate-500 dark:text-slate-400">
            ¿Eres nuevo?
            <a onclick="document.location.href='@Url.Content("~/Account/Register/")'"
               class="font-bold text-primary hover:underline ml-1" href="#">Crear Cuenta</a>
        </p>

        <p class="mt-10 text-center text-sm text-slate-500 dark:text-slate-400">
            ¿Olvidó su contraseña?
            <a onclick="document.location.href='@Url.Content("~/Account/ForgotPassword/")'"
               class="font-bold text-primary hover:underline ml-1" href="#">Click aquí para restablecer</a>
        </p>
    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal(id) {
            document.getElementById(id).classList.add("hidden");
        }

        window.onload = function() {
            var success = '@ViewBag.LoginSuccess';
            if (success === 'True') {
                document.getElementById("loginSuccessModal").classList.remove("hidden");
                setTimeout(function() {
                    window.location.href = '@Url.Action("Index", "Dashboard")';
                }, 3000);
            } else if (success === 'False') {
                document.getElementById("loginFailModal").classList.remove("hidden");
                document.querySelector("input[name='Correo']").value = "";
                document.querySelector("input[name='Contrasena']").value = "";
            }
        }
    </script>
}
