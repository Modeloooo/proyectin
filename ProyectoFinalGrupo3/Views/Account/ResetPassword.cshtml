@model ProyectoFinalGrupo3.Models.ViewModel.ResetPasswordViewModel;
@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "Restablecer Contraseña";
}
<partial name="Partials/_ModalResetExitoso" model="Model" />
<partial name="Partials/_ModalResetFallo" model="Model" />

    <div class="layout-container flex h-full grow flex-col">
        <!-- Header -->
        <header class="flex items-center justify-between border-b border-primary/20 px-6 py-4 md:px-20 lg:px-40">
            <div class="flex items-center gap-3 text-primary">
                <div class="size-8 flex items-center justify-center bg-primary/10 rounded-lg">
                    <span class="material-symbols-outlined">restaurant</span>
                </div>
                <h2 class="text-slate-100 text-xl font-bold tracking-tight">Atelier 27</h2>
            </div>
            <div class="flex items-center gap-4">
                <div class="bg-primary/20 border border-primary/30 rounded-full size-10 flex items-center justify-center overflow-hidden">
                    <span class="material-symbols-outlined text-primary">person</span>
                </div>
            </div>
        </header>
        <!-- Main Content -->
        <main class="flex-1 flex flex-col items-center justify-center px-4 py-12">
            <div class="w-full max-w-[480px] space-y-8">
                <div class="text-center space-y-3">
                    <h1 class="text-slate-100 text-4xl font-black uppercase">Restablecer contraseña</h1>
                    <p class="text-slate-400">Ingresa el código enviado a tu correo y tu nueva contraseña</p>
                </div>

                <!-- Formulario -->
                <form asp-action="ConfirmCode" asp-controller="Account" method="post" class="space-y-6">
                    <!-- Código -->
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-200 text-sm font-semibold uppercase">Código de verificación</span>
                        <input asp-for="CodigoRecuperacion" class="form-input w-full rounded-lg border-slate-300 dark:border-primary/30
                                              bg-white dark:bg-primary/5 text-slate-900 dark:text-slate-100
                                              focus:border-primary focus:ring-1 focus:ring-primary h-14 px-4
                                              placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="Ej: FTPYCT" type="text" />
                        <span asp-validation-for="CodigoRecuperacion" class="text-red-500 text-sm"></span>
                    </label>

                    <!-- Nueva contraseña -->
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-200 text-sm font-semibold uppercase">Contraseña</span>
                        <input asp-for="Contrasena" class="form-input w-full rounded-lg border-slate-300 dark:border-primary/30
                                              bg-white dark:bg-primary/5 text-slate-900 dark:text-slate-100
                                              focus:border-primary focus:ring-1 focus:ring-primary h-14 px-4
                                              placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="••••••••" type="password" />
                        <span asp-validation-for="Contrasena" class="text-red-500 text-sm"></span>
                    </label>

                    <!-- Confirmar contraseña -->
                    <label class="flex flex-col gap-2">
                        <span class="text-slate-700 dark:text-slate-200 text-sm font-semibold uppercase">Confirmar contraseña</span>
                        <input asp-for="ConfirmarContrasena" class="form-input w-full rounded-lg border-slate-300 dark:border-primary/30
                                              bg-white dark:bg-primary/5 text-slate-900 dark:text-slate-100
                                              focus:border-primary focus:ring-1 focus:ring-primary h-14 px-4
                                              placeholder:text-slate-400 dark:placeholder:text-slate-600" placeholder="••••••••" type="password" />
                        <span asp-validation-for="ConfirmarContrasena" class="text-red-500 text-sm"></span>
                    </label>

                    <!-- Botón -->
                    <div class="pt-4">
                        <button type="submit" class="w-full h-14 bg-primary text-white font-bold rounded-lg">
                            Restablecer contraseña
                        </button>
                    </div>
                </form>
            </div>
        </main>
        <!-- Footer Decor -->
        <footer class="p-8 flex justify-center opacity-30">
            <div class="flex gap-4">
                <div class="size-1 rounded-full bg-primary"></div>
                <div class="size-1 rounded-full bg-primary"></div>
                <div class="size-1 rounded-full bg-primary"></div>
            </div>
        </footer>
    </div>
    <!-- Decorative Background Elements -->
    <div class="fixed top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="fixed bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function closeModal(id) {
            document.getElementById(id).classList.add("hidden");
        }

        window.onload = function() {
            var success = '@ViewBag.ResetSuccess';
            if (success === 'True') {
                document.getElementById("resetSuccessModal").classList.remove("hidden");
                setTimeout(function() {
                    window.location.href = '@Url.Action("Login", "Account")';
                }, 3000);
            } else if (success === 'False') {
                document.getElementById("resetFailModal").classList.remove("hidden");
            }
        }
    </script>
}