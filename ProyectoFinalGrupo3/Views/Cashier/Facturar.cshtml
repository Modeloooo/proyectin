@model ProyectoFinalGrupo3.Models.Pedido

@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "Facturar";
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <div class="p-6 lg:p-10">
        <div class="mb-8">
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                Facturar Pedido #@Model.CodigoPedido
            </h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">
                @Model.TipoPedido | @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Productos -->
            <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl p-6">
                <h3 class="text-lg font-bold mb-4">Productos</h3>
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-primary/10">
                            <th class="py-2 text-left">Producto</th>
                            <th class="py-2 text-center">Cant</th>
                            <th class="py-2 text-right">Precio</th>
                            <th class="py-2 text-right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.PedidoDetalles)
                        {
                            <tr class="border-b border-primary/5">
                                <td class="py-2">
                                    @d.CodigoProductoNavigation?.Nombre
                                    @if (Model.TipoPedido == "Takeout" && (d.CodigoProductoNavigation?.RequiereEmpaque ?? 0) == 1)
                                    {
                                        <span class="text-xs text-amber-600 block">
                                            📦 +₡@d.CodigoProductoNavigation?.CostoEmpaque.ToString("N0") empaque c/u
                                        </span>
                                    }
                                </td>
                                <td class="py-2 text-center">@d.Cantidad</td>
                                <td class="py-2 text-right">₡@d.PrecioUnitario.ToString("N2")</td>
                                <td class="py-2 text-right">₡@((d.Cantidad * d.PrecioUnitario).ToString("N2"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Totales -->
            <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl p-6">
                <h3 class="text-lg font-bold mb-4">Totales</h3>
                
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span>Subtotal:</span>
                        <span>₡@ViewBag.Subtotal.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between">
                        <span>IVA (13%):</span>
                        <span>₡@ViewBag.IVA.ToString("N2")</span>
                    </div>
                    @if (Model.TipoPedido == "Dine-in")
                    {
                        <div class="flex justify-between">
                            <span>Propina (10%):</span>
                            <span>₡@ViewBag.Propina.ToString("N2")</span>
                        </div>
                    }
                    @if (Model.TipoPedido == "Takeout" && ViewBag.CostoEmpaque > 0)
                    {
                        <div class="flex justify-between">
                            <span>Costo Empaque:</span>
                            <span>₡@ViewBag.CostoEmpaque.ToString("N2")</span>
                        </div>
                    }
                    @if (Model.TipoPedido == "Delivery")
                    {
                        <div class="flex justify-between">
                            <span>Delivery:</span>
                            <span>₡@ViewBag.CostoDelivery.ToString("N2")</span>
                        </div>
                    }
                    
                    @if (Model.IdUsuarioNavigation?.DineroDisponible > 0)
                    {
                        <div class="flex justify-between text-green-600">
                            <span>Saldo a favor:</span>
                            <span>-₡@Model.IdUsuarioNavigation.DineroDisponible?.ToString("N2")</span>
                        </div>
                    }
                    
                    <hr class="my-3 border-primary/20" />
                    
                    <div class="flex justify-between text-xl font-black">
                        <span>TOTAL A PAGAR:</span>
                        <span class="text-primary">₡@ViewBag.Total.ToString("N2")</span>
                    </div>
                </div>

                <form asp-action="ProcesarPago" method="post" class="mt-6">
                    <input type="hidden" name="codigoPedido" value="@Model.CodigoPedido" />
                    
                    <div class="space-y-2">
                        <label class="text-sm font-bold">Monto recibido</label>
                        <input type="number" name="montoPagado" step="0.01" min="@ViewBag.Total"
                               class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-lg outline-none"
                               required />
                    </div>

                    <div class="flex gap-4 mt-6">
                        <a asp-action="Index" class="px-6 py-2.5 text-sm text-slate-500 hover:text-slate-700">
                            Cancelar
                        </a>
                        <button type="submit" class="flex-1 px-6 py-2.5 bg-green-600 text-white rounded-xl font-bold hover:bg-green-700">
                            Procesar Pago
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>