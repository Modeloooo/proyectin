@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "Categories";

}

<partial name="Partials/_ModalEliminar" model="Model" />
<partial name="Partials/_ModalEditar" model="Model" />
<partial name="Partials/_ModalVer" model="Model" />
<partial name="Partials/_ModalAgregar" model="Model" />
<partial name="Partials/_ModalError" model="Model" />


<div class="p-6 lg:p-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">Mantenimiento de Categorias</h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">Gestiona las Categorias.</p>
        </div>
        <button id="btnAgregar" class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-slate-100 px-6 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined">category</span>
            <span>Añadir Nueva Categoria</span>
        </button>
    </div>
    <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-primary/5 border-b border-primary/20">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Categoría</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Descripción</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-primary/10">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-primary/5 transition-colors group">
                            <td class="px-6 py-5 text-sm font-medium text-primary/60">
                                CAT#@item.CodigoCategoria
                            </td>
                            <td class="px-6 py-5 text-sm text-slate-500 dark:text-slate-400">
                                @item.Descripcion
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex justify-center gap-2">
                                    <button class="btnVer p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all" title="Ver"
                                            data-id="@item.CodigoCategoria"
                                            data-descripcion="@item.Descripcion">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>
                                    <button class="btnEditar p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all" title="Editar"
                                            data-id="@item.CodigoCategoria"
                                            data-descripcion="@item.Descripcion">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </button>
                                    <button class="btnEliminar p-2 rounded-lg hover:bg-red-500/10 text-slate-400 hover:text-red-500 transition-all" title="Eliminar"
                                            data-id="@item.CodigoCategoria">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Footer / Pagination -->
        <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
            <p class="text-xs text-slate-500 dark:text-primary/60">Mostrando 5 de 12 categorías registradas</p>
            <div class="flex gap-1">
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-primary hover:bg-primary hover:text-slate-100 transition-all cursor-not-allowed opacity-50">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </button>
                <button class="size-8 flex items-center justify-center rounded-lg bg-primary text-slate-100 font-bold text-xs">1</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-slate-500 hover:text-primary hover:bg-primary/10 transition-all font-bold text-xs">2</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-slate-500 hover:text-primary hover:bg-primary/10 transition-all font-bold text-xs">3</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-primary hover:bg-primary hover:text-slate-100 transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
    <!-- Sticky Footer -->
    <footer class="mt-auto p-6 border-t border-primary/10 bg-background-dark/20 text-center">
        <p class="text-[10px] text-slate-500 uppercase tracking-[0.2em]">© 2024 Atelier 27 Restaurant · All Rights Reserved · Dashboard v2.0</p>
    </footer>
</div>
@section Scripts {
    <script src="~/js/categorias.js"></script>
}