@model IEnumerable<ProyectoFinalGrupo3.Models.Factura>

@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "History";
    var usuarios = ViewBag.Usuarios as List<Usuarios>;
    var usuarioFiltro = ViewBag.UsuarioFiltro as string;
    var fechaInicio = ViewBag.FechaInicio as string;
    var fechaFin = ViewBag.FechaFin as string;
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <div class="p-6 lg:p-10">
        <div class="mb-8">
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                Historial de Compras
            </h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">
                Visualiza y gestiona todas las facturas emitidas
            </p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-700 dark:text-green-400">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-700 dark:text-red-400">
                @TempData["Error"]
            </div>
        }

        <!-- Filtros -->
        <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl p-6 mb-6">
            <form method="get" asp-action="Index" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
                <!-- Filtro por Usuario -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Filtrar por Cliente</label>
                    <select name="usuarioId" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                        <option value="">Todos los clientes</option>
                        @if (usuarios != null)
                        {
                            @foreach (var u in usuarios)
                            {
                                <option value="@u.Identificacion" selected="@(usuarioFiltro == u.Identificacion ? "selected" : null)">
                                    @u.NombreCompleto (@u.Identificacion)
                                </option>
                            }
                        }
                    </select>
                </div>

                @if (User.IsInRole("Contador") || User.IsInRole("Administrador"))
                {
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Fecha Inicio</label>
                        <input type="date" name="fechaInicio" value="@fechaInicio"
                               class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Fecha Fin</label>
                        <input type="date" name="fechaFin" value="@fechaFin"
                               class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                    </div>
                }

                <div class="flex gap-2">
                    <button type="submit" class="px-6 py-3 bg-primary text-white rounded-xl font-bold text-sm hover:bg-primary/90">
                        <span class="material-symbols-outlined align-middle text-lg">filter_alt</span>
                        Filtrar
                    </button>
                    <a asp-action="Index" class="px-6 py-3 border border-primary/20 rounded-xl font-bold text-sm hover:bg-primary/10">
                        Limpiar
                    </a>
                </div>
            </form>
        </div>

        <!-- Tabla de Facturas -->
        <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-primary/5 border-b border-primary/20">
                            <th class="px-6 py-4 text-xs font-bold uppercase"># Factura</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Fecha</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Cliente</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Tipo</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Subtotal</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">IVA</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Total</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-primary/10">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var factura in Model)
                            {
                                var pedido = factura.CodigoPedidoNavigation;
                                var usuario = pedido?.IdUsuarioNavigation;
                                var horasTranscurridas = factura.Fecha.HasValue ? (DateTime.Now - factura.Fecha.Value).TotalHours : 999;
                                var puedeReversar = horasTranscurridas <= 24 && (User.IsInRole("Administrador") || User.IsInRole("Contador"));

                                <tr class="hover:bg-primary/5">
                                    <td class="px-6 py-5 font-bold text-primary">#@factura.NumeroFactura</td>
                                    <td class="px-6 py-5 text-sm">@factura.Fecha?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-6 py-5 text-sm">@(usuario?.NombreCompleto ?? "Cliente genérico")</td>
                                    <td class="px-6 py-5 text-sm">@(pedido?.TipoPedido ?? "N/A")</td>
                                    <td class="px-6 py-5 text-sm">₡@factura.Subtotal?.ToString("N2")</td>
                                    <td class="px-6 py-5 text-sm">₡@factura.Iva?.ToString("N2")</td>
                                    <td class="px-6 py-5 text-sm font-bold">₡@factura.Total?.ToString("N2")</td>
                                    <td class="px-6 py-5 text-center">
                                        <div class="flex justify-center gap-2">
                                            <a asp-action="DetalleFactura" asp-route-id="@factura.NumeroFactura"
                                                   class="p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary" title="Ver detalle">
                                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                                            </a>
                                            
                                            @if (puedeReversar)
                                            {
                                                <form asp-action="Reversar" method="post" class="inline"
                                                      onsubmit="return confirm('¿Está seguro de reversar esta factura? El monto quedará como saldo a favor del cliente.')">
                                                    <input type="hidden" name="facturaId" value="@factura.NumeroFactura" />
                                                    <button type="submit" class="p-2 rounded-lg hover:bg-red-500/10 text-slate-400 hover:text-red-500" title="Reversar">
                                                        <span class="material-symbols-outlined text-[20px]">undo</span>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="px-6 py-10 text-center text-slate-500">
                                    No hay facturas registradas.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
                <p class="text-xs text-slate-500">
                    Mostrando @(Model?.Count() ?? 0) factura(s)
                </p>
            </div>
        </div>
    </div>
</main>