@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "History";

}
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header section -->
            <header class="p-8 pb-4">
                <div class="flex flex-col gap-2">
                    <h2 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white">Historial de Compras</h2>
                    <p class="text-slate-500 dark:text-slate-400">Consulte y gestione todas las transacciones pasadas del restaurante.</p>
                </div>
            </header>
            <!-- Filters & Search Section -->
            <section class="px-8 py-4 flex flex-col gap-4">
                <div class="flex flex-wrap gap-4 items-center">
                    <div class="relative flex-1 min-w-[300px]">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-primary/50">search</span>
                        <input class="w-full pl-12 pr-4 py-3 bg-white dark:bg-white/5 border border-slate-200 dark:border-primary/20 rounded-xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500" placeholder="Buscar por ID de pedido o cliente..." type="text" />
                    </div>
                    <div class="flex gap-2">
                        <button class="flex items-center gap-2 px-4 py-3 bg-white dark:bg-white/5 border border-slate-200 dark:border-primary/20 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-white/10 transition-colors">
                            <span class="material-symbols-outlined text-xl">calendar_today</span>
                            Hoy
                            <span class="material-symbols-outlined text-sm">expand_more</span>
                        </button>
                        <button class="flex items-center gap-2 px-4 py-3 bg-white dark:bg-white/5 border border-slate-200 dark:border-primary/20 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-white/10 transition-colors">
                            Últimos 7 días
                            <span class="material-symbols-outlined text-sm">expand_more</span>
                        </button>
                        <button class="flex items-center gap-2 px-4 py-3 bg-white dark:bg-white/5 border border-slate-200 dark:border-primary/20 rounded-xl text-sm font-medium hover:bg-slate-50 dark:hover:bg-white/10 transition-colors text-primary">
                            <span class="material-symbols-outlined text-xl">filter_list</span>
                            Más Filtros
                        </button>
                    </div>
                </div>
            </section>
