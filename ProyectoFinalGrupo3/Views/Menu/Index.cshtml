@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "History";
}
    <div class="relative flex min-h-screen flex-col overflow-x-hidden w-full">
        <!-- Header Section -->
        <header class="sticky top-0 z-50 w-full border-b border-border-dark bg-background-dark/95 backdrop-blur-md px-6 md:px-20 py-4">
            <div class="max-w-[1200px] mx-auto flex items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="text-primary">
                        <span class="material-symbols-outlined text-4xl">restaurant_menu</span>
                    </div>
                    <h1 class="text-2xl font-bold tracking-tight text-slate-100 uppercase">Atelier 27</h1>
                </div>
                <div class="hidden md:flex flex-1 max-w-md mx-8">
                    <div class="relative w-full">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-primary">search</span>
                        <input class="w-full bg-surface-dark border-none rounded-lg py-2 pl-10 pr-4 text-slate-100 placeholder:text-slate-500 focus:ring-1 focus:ring-primary" placeholder="Buscar en nuestro exquisito menú..." type="text" />
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <button class="p-2 text-slate-100 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">person</span>
                    </button>
                    <div class="h-10 w-10 rounded-full bg-primary/20 border border-primary/30 flex items-center justify-center overflow-hidden">
                        <div class="w-full h-full bg-cover bg-center" data-alt="User profile avatar placeholder" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDbEm1poU6PbIHBNrmxP3ZKfsLr40_74vFUFLXqddgrd9zeSQLQLZ8bvC2U2HZEHJggFdQd3hQ4nPrsnE_q9_VQMh0R33-R6SB9qyJMekQwcVD5shvlefQPit4VtsTd7F8ZnKDGfM88jkU0KU85kHEr4ehxHVBZRHpMV9DxZdcBGFVXZd6IfbDqOYqOW2cklGZmjo3ZKMcE7xi2RyG648oPQCeWjcglhw30HU11HbI_G2zNJ1DiI4vFbKP1XwDoG6zFPuq53bSVu-56')"></div>
                    </div>
                </div>
            </div>
        </header>
        <main class="flex-1 w-full max-w-[1200px] mx-auto px-6 md:px-10 py-8">
            <!-- Category Navigation -->
            <div class="flex gap-3 overflow-x-auto pb-6 no-scrollbar">
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-primary text-white font-medium shadow-lg shadow-primary/20"><span class="material-symbols-outlined text-sm">star</span>Especiales</button>
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-surface-dark text-slate-300 hover:bg-primary/20 hover:text-primary transition-all border border-border-dark">
                    Entradas
                </button>
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-surface-dark text-slate-300 hover:bg-primary/20 hover:text-primary transition-all border border-border-dark">
                    Platos Fuertes
                </button>
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-surface-dark text-slate-300 hover:bg-primary/20 hover:text-primary transition-all border border-border-dark">
                    Postres
                </button>
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-surface-dark text-slate-300 hover:bg-primary/20 hover:text-primary transition-all border border-border-dark">
                    Bebidas
                </button>
                <button class="flex items-center gap-2 whitespace-nowrap px-6 py-2 rounded-full bg-surface-dark text-slate-300 hover:bg-primary/20 hover:text-primary transition-all border border-border-dark">
                    Vinos
                </button>
            </div>
            <!-- Section Title -->
            <div class="flex items-end justify-between mb-8">
                <div>
                    <h2 class="text-3xl font-bold text-slate-100">Selección de la Casa</h2>
                    <p class="text-primary/80 font-medium">Curada por nuestro Chef de Cocine</p>
                </div>
                <div class="hidden sm:flex gap-2">
                    <button class="p-2 rounded-lg bg-surface-dark text-slate-400 border border-border-dark">
                        <span class="material-symbols-outlined">tune</span>
                    </button>
                </div>
            </div>
            <!-- Menu Grid -->
