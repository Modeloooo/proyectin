                        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110" data-alt="Glass of premium Red Wine from a cellar" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAb0L5inIo8eZizDJ7ycxjEwapZWA3E5pQMBybou7yiivMHp8Vnd6TmK5Tdi5zUIYjWI74Q5Jm1MUImXK9B-bGndNyq8VsuY-ImWsvR6Nu4wHpyqfiiwoVAEkr3-q72dCAYOwqJMIsD-7mggpDHgN3ovdbtopxSHQgtoNDs1l0xPqAWMvrNz1E5tfqK1mOwBNlsK0wJl-Df_fnFptmtTbREIMcYcic0LWNAdj4I3pBWiXsOpN4VLtAjsGsibrZsy-dbVV33FzfM-NHC')"></div>
                        <div class="absolute top-3 right-3 bg-background-dark/80 backdrop-blur-md px-3 py-1 rounded-full text-primary font-bold">
                            €14.00
                        </div>
                    </div>
