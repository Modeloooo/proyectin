                    </div>
                </div>
            </div>
        </main>
        <!-- Floating View Cart Button -->
        <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50">
            <button class="flex items-center gap-4 bg-primary px-8 py-4 rounded-full shadow-2xl shadow-primary/40 hover:scale-105 active:scale-95 transition-all text-white">
                <div class="relative">
                    <span class="material-symbols-outlined text-2xl">shopping_bag</span>
                    <span class="absolute -top-2 -right-2 bg-white text-primary text-[10px] font-bold h-5 w-5 rounded-full flex items-center justify-center">3</span>
                </div>
                <div class="text-left">
                    <p class="text-xs opacity-80 uppercase font-bold tracking-widest">TU PEDIDO</p>
                    <p class="text-lg font-bold leading-tight">Ver Carrito • €78.00</p>
                </div>
            </button>
        </div>
        <!-- Navigation Overlay / Mini-Sidebar indicator for mobile -->
        <div class="fixed right-6 bottom-8 z-50 flex flex-col gap-4">
            <button class="size-12 rounded-full bg-surface-dark border border-border-dark flex items-center justify-center text-primary shadow-xl">
                <span class="material-symbols-outlined">support_agent</span>
            </button>
            <button class="size-12 rounded-full bg-surface-dark border border-border-dark flex items-center justify-center text-primary shadow-xl">
                <span class="material-symbols-outlined">info</span>
            </button>
        </div>
    </div>
    <style>
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>