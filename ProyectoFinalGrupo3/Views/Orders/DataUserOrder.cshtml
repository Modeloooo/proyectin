@model ProyectoFinalGrupo3.Models.DataUCViewModel

@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "Finalizar Pedido";
    var productos = ViewBag.Productos as List<ProyectoFinalGrupo3.Models.Producto>;
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto bg-background-light dark:bg-background-dark">
    <div class="max-w-4xl mx-auto w-full p-6 lg:p-10">
        <div class="mb-8">
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                Finalizar Pedido
            </h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">
                Revisa tu pedido y confirma los datos de entrega
            </p>
        </div>

        @if (ViewBag.OrderSuccess == "True")
        {
            <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-6 text-center mb-6">
                <span class="material-symbols-outlined text-4xl text-green-500 mb-2">check_circle</span>
                <h3 class="text-xl font-bold text-green-600 dark:text-green-400">¡Pedido Confirmado!</h3>
                <p class="text-slate-500">Tu pedido ha sido registrado exitosamente.</p>
                <a asp-action="CreateUserOrder" class="inline-block mt-4 px-6 py-2 bg-primary text-white rounded-xl font-bold">
                    Seguir Comprando
                </a>
            </div>
        }
        else
        {
            @if (ViewBag.OrderSuccess == "False")
            {
                <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6 text-red-600">
                    @ViewBag.OrderMessage
                </div>
            }

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Columna izquierda: Datos del cliente y método -->
                <div class="space-y-6">
                    <div class="bg-white dark:bg-surface-dark border border-primary/20 rounded-xl p-6">
                        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">person</span>
                            Datos del Cliente
                        </h3>
                        
                        <div class="space-y-3">
                            <div>
                                <p class="text-xs text-slate-500">Nombre</p>
                                <p class="font-bold">@Model.Usuario?.NombreCompleto</p>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500">Correo</p>
                                <p>@Model.Usuario?.Correo</p>
                            </div>
                            <div>
                                <p class="text-xs text-slate-500">Identificación</p>
                                <p class="font-mono">@Model.Usuario?.Identificacion</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-surface-dark border border-primary/20 rounded-xl p-6">
                        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">local_shipping</span>
                            Método de Entrega
                        </h3>
                        
                        <form asp-action="SeleccionarMetodo" method="post" id="formMetodo">
                            <div class="space-y-3">
                                <label class="flex items-center gap-3 p-3 border border-primary/20 rounded-xl cursor-pointer hover:bg-primary/5">
                                    <input type="radio" name="metodo" value="Takeout" checked
                                           class="w-4 h-4 text-primary" />
                                    <div>
                                        <span class="font-bold">Retiro en Local (Takeout)</span>
                                        <p class="text-xs text-slate-500">Recoge tu pedido en nuestro restaurante</p>
                                    </div>
                                </label>
                                
                                <label class="flex items-center gap-3 p-3 border border-primary/20 rounded-xl cursor-pointer hover:bg-primary/5">
                                    <input type="radio" name="metodo" value="Delivery"
                                           class="w-4 h-4 text-primary" />
                                    <div>
                                        <span class="font-bold">Delivery a Domicilio</span>
                                        <p class="text-xs text-slate-500">+₡2,000 costo de envío</p>
                                    </div>
                                </label>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Columna derecha: Resumen del pedido -->
                <div class="bg-white dark:bg-surface-dark border border-primary/20 rounded-xl p-6">
                    <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">receipt</span>
                        Resumen del Pedido
                    </h3>
                    
                    <div class="space-y-3 max-h-80 overflow-y-auto mb-4">
                        @foreach (var item in Model.Carrito)
                        {
                            var producto = productos?.FirstOrDefault(p => p.CodigoProducto == item.CodigoProducto);
                            <div class="flex justify-between items-center border-b border-primary/10 pb-3">
                                <div>
                                    <p class="font-bold">@item.Nombre</p>
                                    <p class="text-sm text-slate-500">@item.Cantidad x ₡@item.Precio.ToString("N2")</p>
                                    @if (producto != null && producto.RequiereEmpaque == 1)
                                    {
                                        <p class="text-xs text-amber-600 flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">inventory_2</span>
                                            +₡@producto.CostoEmpaque.ToString("N0") empaque c/u
                                        </p>
                                    }
                                </div>
                                <p class="font-bold">₡@((item.Cantidad * item.Precio).ToString("N2"))</p>
                            </div>
                        }
                    </div>
                    
                    <hr class="my-4 border-primary/20" />
                    
                    <div class="space-y-2">
                        <div class="flex justify-between">
                            <span class="text-slate-500">Subtotal</span>
                            <span>₡@Model.Subtotal.ToString("N2")</span>
                        </div>
                        
                        <div class="flex justify-between">
                            <span class="text-slate-500">IVA (13%)</span>
                            <span>₡@Model.IVA.ToString("N2")</span>
                        </div>
                        
                        @{
                            decimal costoEmpaqueTotal = 0;
                            if (Model.MetodoEntrega == "Takeout")
                            {
                                costoEmpaqueTotal = Model.Carrito.Sum(c =>
                                    (productos?.FirstOrDefault(p => p.CodigoProducto == c.CodigoProducto)?.CostoEmpaque ?? 0) * c.Cantidad);
                                
                                if (costoEmpaqueTotal > 0)
                                {
                                    <div class="flex justify-between">
                                        <span class="text-slate-500">Costo de Empaque</span>
                                        <span>₡@costoEmpaqueTotal.ToString("N2")</span>
                                    </div>
                                }
                            }
                        }
                        
                        @if (Model.MetodoEntrega == "Delivery")
                        {
                            <div class="flex justify-between">
                                <span class="text-slate-500">Costo de Envío</span>
                                <span>₡2,000.00</span>
                            </div>
                        }
                        
                        <hr class="my-2 border-primary/20" />
                        
                        @{
                            var totalFinal = Model.Subtotal + Model.IVA;
                            if (Model.MetodoEntrega == "Takeout")
                                totalFinal += costoEmpaqueTotal;
                            else if (Model.MetodoEntrega == "Delivery")
                                totalFinal += 2000;
                        }
                        
                        <div class="flex justify-between text-lg font-black">
                            <span>TOTAL A PAGAR</span>
                            <span class="text-primary">₡@totalFinal.ToString("N2")</span>
                        </div>
                    </div>
                    
                    <form asp-action="ConfirmarPedido" method="post" class="mt-6">
                        <input type="hidden" name="metodoEntrega" id="metodoEntrega" value="@Model.MetodoEntrega" />
                        <button type="submit" class="w-full py-3 bg-primary text-white rounded-xl font-bold text-lg hover:bg-primary/90 transition-all">
                            Confirmar Pedido
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const radios = document.querySelectorAll('input[name="metodo"]');
        const metodoHidden = document.getElementById('metodoEntrega');
        
        radios.forEach(radio => {
            radio.addEventListener('change', function() {
                metodoHidden.value = this.value;
                document.getElementById('formMetodo').submit();
            });
        });
        
        // Establecer valor inicial
        const seleccionado = document.querySelector('input[name="metodo"]:checked');
        if (seleccionado) {
            metodoHidden.value = seleccionado.value;
        }
    });
</script>