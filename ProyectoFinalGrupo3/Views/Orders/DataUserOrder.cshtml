@model ProyectoFinalGrupo3.Models.DataUCViewModel;
@{
    Layout = "~/Views/Shared/_CustomLayoutPublic.cshtml";
    ViewData["Title"] = "Finalizar Pedido";
}

<main class="bg-background text-on-background min-h-screen pt-12 md:pt-24 pb-12 px-4 md:px-8 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 relative">
    
    <!-- Order Modals -->
    <div id="orderSuccessModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-background-dark/80 backdrop-blur-sm">
        <div class="w-full max-w-sm bg-background-dark border border-green-900/50 rounded-xl p-8 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-green-600/50"></div>
            <div class="flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-green-950/30 rounded-full flex items-center justify-center mb-6 border border-green-900/30">
                    <span class="material-symbols-outlined text-green-500 text-4xl">shopping_bag</span>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">¡Pedido Confirmado!</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-8">
                    Tu orden se generó exitosamente y la cocina está preparada.
                </p>
                <a href="/Users/HomeUser" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-6 rounded-lg transition-all shadow-lg shadow-primary/10 flex items-center justify-center">
                    Ver mis pedidos
                </a>
            </div>
        </div>
    </div>

    <div id="orderFailModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-background-dark/80 backdrop-blur-sm">
        <div class="w-full max-w-sm bg-background-dark border border-red-900/50 rounded-xl p-8 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-red-600/50"></div>
            <div class="flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-red-950/30 rounded-full flex items-center justify-center mb-6 border border-red-900/30">
                    <span class="material-symbols-outlined text-red-500 text-4xl">error</span>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Error en el Pedido</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-8">
                    @(ViewBag.OrderMessage ?? "Verifique los datos ingresados.")
                </p>
                <button onclick="document.getElementById('orderFailModal').classList.add('hidden')" class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-3 px-6 rounded-lg transition-all shadow-lg shadow-primary/10">
                    Reintentar
                </button>
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="lg:col-span-8">
        <h1 class="font-headline text-3xl font-bold tracking-tight mb-8 text-on-surface">Finalizar Pedido</h1>
        <section class="space-y-12">
            
            <!-- Section 1: Datos del Cliente -->
            <div class="space-y-6">
                <div class="flex items-center justify-between border-b border-outline-variant pb-2">
                    <h2 class="text-[12px] uppercase tracking-[0.2em] font-bold text-primary">Datos del Cliente</h2>
                    <button type="button" class="text-[10px] uppercase tracking-widest font-bold text-stone-500 hover:text-primary transition-colors">Editar</button>
                </div>
                <div class="relative group md:col-span-2">
                    <label class="absolute-top-2:1.2 left-3 bg-background px-2 text-[10px] uppercase tracking-widest font-bold text-stone-500 transition-colors group-focus-within:text-primary">Identificación</label>
                    <input class="w-full bg-slate-100 dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" readonly type="tel" value="@Model.Usuario.Identificacion" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="relative group">
                        <label class="absolute-top-2:1.2 left-3 bg-background px-2 text-[10px] uppercase tracking-widest font-bold text-stone-500 transition-colors group-focus-within:text-primary">Nombre Completo</label>
                        <input class="w-full bg-slate-100 dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" readonly type="text" value="@Model.Usuario.NombreCompleto" />
                    </div>
                    <div class="relative group">
                        <label class="absolute-top-2:1.2 left-3 bg-background px-2 text-[10px] uppercase tracking-widest font-bold text-stone-500 transition-colors group-focus-within:text-primary">Correo</label>
                        <input class="w-full bg-slate-100 dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" readonly type="email" value="@Model.Usuario.Correo" />
                    </div>
                </div>
            </div>

            <!-- Section 2: Opciones de Retiro -->
            <div class="space-y-6">
                <div class="border-b border-outline-variant pb-2">
                    <h2 class="text-[12px] uppercase tracking-[0.2em] font-bold text-primary">Método de Entrega</h2>
                </div>
                
                <!-- Toggle Options -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="relative cursor-pointer group">
                        <input type="radio" name="delivery_method" value="Local" class="peer sr-only" id="methodLocal" checked />
                        <div class="p-6 rounded-xl border peer-checked:border-primary peer-checked:bg-primary-container">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined text-primary">store</span>
                                <div>
                                    <p class="text-sm font-bold">Retiro en Local</p>
                                    <p class="text-[10px] uppercase tracking-widest text-emerald-500">Sin costo adicional</p>
                                </div>
                            </div>
                        </div>
                    </label>

                    <label class="relative cursor-pointer group">
                        <input type="radio" name="delivery_method" value="Delivery" class="peer sr-only" id="methodDelivery" />
                        <div class="p-6 rounded-xl border peer-checked:border-primary peer-checked:bg-primary-container">
                            <div class="flex items-center gap-4">
                                <span class="material-symbols-outlined peer-checked:text-primary">delivery_dining</span>
                                <div>
                                    <p class="text-sm font-bold">Entrega a Domicilio</p>
                                    <p class="text-[10px] uppercase tracking-widest text-slate-500">₡2,000.00 adicional</p>
                                </div>
                            </div>
                        </div>
                    </label>
                </div>
                
                <!-- Pickup Details (Visible by default) -->
                <div id="localPickupDetails" class="bg-surface-container-high rounded-2xl p-8 border border-outline-variant flex flex-col md:flex-row gap-8 items-center transition-all duration-300">
                    <div class="w-full md:w-48 h-48 rounded-xl overflow-hidden shadow-2xl relative shrink-0 border border-primary/10">
                        <img alt="Restaurant Interior" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCN_5t2v71AXC1HGircjq97XfuIEgAsJLS5i_geEsLmeJOmb99JRCsRaEOUZ-OZhGgiekxg7tYKHv3sqUxduTyDuneIdBIz5Uw1r3wiluDmi_Qh42BYjrW6uNCb7vwAK7a10fH9hyUdSCtVNOygWME5yZMAQJZeUzxsyrRdBMJOEy6IcXyC7LdxQ9WKMCIN4_pmqbTVLfTBa-XCjaiZrW-a1NKaPdkU2kM-k9yJaT09iQWOxHWAldeeEhkVx-5QlbEZcKi8zUGVQ-rl" />
                        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent"></div>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <h3 class="text-lg font-bold text-primary">Atelier 27 - Sede Central</h3>
                            <p class="text-sm text-stone-400">Av. Alvear 1891, Recoleta, CABA</p>
                        </div>
                        <div class="flex items-center gap-2 text-xs text-stone-500">
                            <span class="material-symbols-outlined text-[16px]">schedule</span>
                            <span>Disponible para retirar en 25-40 min</span>
                        </div>
                        <button class="flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] font-bold text-primary hover:brightness-110 transition-all">
                            <span class="material-symbols-outlined text-[16px]">map</span>
                            Ver en mapa
                        </button>
                    </div>
                </div>

                <!-- Delivery Details -->
                <div id="deliveryDetails" class="hidden bg-surface-container-high rounded-2xl p-8 border border-outline-variant flex flex-col gap-4 items-start transition-all duration-300">
                    <h3 class="text-lg font-bold text-primary flex items-center gap-2"><span class="material-symbols-outlined">home_pin</span> Dirección de Entrega</h3>
                    <div class="w-full">
                        <textarea class="w-full bg-slate-100 dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all resize-none h-24" placeholder="Ej: Condominio Las Palmas, Torre 3, Apto 402..."></textarea>
                    </div>
                </div>

            </div>

            <!-- Section 3: Opciones de Pago -->
            <div class="space-y-6">
                <div class="border-b border-outline-variant pb-2">
                    <h2 class="text-[12px] uppercase tracking-[0.2em] font-bold text-primary">Método De Pago</h2>
                </div>

                <!-- Toggle Options -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <label class="relative cursor-pointer group">
                        <input checked id="payCard" class="peer sr-only" name="payment_method" type="radio" value="tarjeta" />
                        <div class="p-6 rounded-xl border border-outline bg-surface-container transition-all peer-checked:border-primary peer-checked:bg-primary-container group-hover:bg-surface-container-high">
                            <span class="material-symbols-outlined text-primary mb-3 block" data-icon="credit_card">credit_card</span>
                            <div class="text-xs font-bold uppercase tracking-tight">Tarjeta de Crédito</div>
                        </div>
                    </label>
                    <label class="relative cursor-pointer group">
                        <input class="peer sr-only" id="payCash" name="payment_method" type="radio" value="efectivo" />
                        <div class="p-6 rounded-xl border border-outline bg-surface-container transition-all peer-checked:border-primary peer-checked:bg-primary-container group-hover:bg-surface-container-high">
                            <span class="material-symbols-outlined text-primary mb-3 block" data-icon="payments">payments</span>
                            <div class="text-xs font-bold uppercase tracking-tight">Efectivo</div>
                        </div>
                    </label>
                </div>
                
                <!-- Tarjeta Wrapper -->
                <div id="creditCardWrapper" class="transition-all duration-300 overflow-hidden space-y-6 border border-primary/10 rounded-2xl p-6 bg-slate-50 dark:bg-white/5">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Número de Tarjeta</label>
                            <div class="relative group focus-within:text-primary">
                                <input class="w-full bg-white dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" type="text" maxlength="16" placeholder="0000 0000 0000 0000" value="@Model.Usuario.NumeroTarjeta" />
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined transition-colors">lock</span>
                            </div>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Nombre en la Tarjeta</label>
                            <input class="w-full bg-white dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" value="@Model.Usuario.NombreCompleto" type="text" />
                        </div>
                        <div class="flex flex-col gap-2 relative">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Vencimiento</label>
                            <input class="w-full bg-white dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" placeholder="MM/YY" type="text" maxlength="5" />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">CVV</label>
                            <input class="w-full bg-white dark:bg-slate-900/50 border border-primary/20 focus:border-primary rounded-lg px-4 py-3 text-slate-900 dark:text-slate-100 outline-none transition-all" placeholder="***" type="password" maxlength="4" />
                        </div>
                    </div>
                </div>

                <div id="cashWrapper" class="hidden p-6 bg-slate-100 dark:bg-slate-800/50 rounded-xl border border-primary/20 text-center">
                    <span class="material-symbols-outlined text-4xl text-primary mb-2">payments</span>
                    <h3 class="font-bold text-slate-700 dark:text-slate-200">Pago Contra Entrega</h3>
                    <p class="text-sm text-slate-500 mt-2">Pagarás el total exacto en efectivo al recepcionista cuando te entregue tu pedido.</p>
                </div>

            </div>
        </section>
    </div>

    <!-- Aside Panel -->
    <aside class="lg:col-span-4 self-start sticky top-24 w-full bg-white dark:bg-surface-dark border-l md:border md:rounded-2xl border-slate-200 dark:border-accent-dark p-8 flex flex-col justify-between overflow-y-auto shadow-xl">
        <div>
            <h3 class="text-2xl font-bold dark:text-white mb-8">Resumen Final</h3>

            <!-- Lista de productos -->
            <div class="space-y-3 mb-6">
                @foreach (var item in Model.Carrito)
                {
                    <div class="flex justify-between text-slate-700 dark:text-slate-300 text-sm border-b border-primary/5 pb-2">
                        <span class="font-medium text-slate-500">@item.Nombre <span class="text-primary font-bold ml-1">x@(item.Cantidad)</span></span>
                        <span class="font-bold">₡@((item.Precio * item.Cantidad).ToString("N2"))</span>
                    </div>
                }
            </div>
            
            <!-- Totales -->
            <div class="space-y-4 pt-4">
                <div class="flex justify-between text-slate-600 dark:text-slate-400">
                    <span>Subtotal</span>
                    <span class="font-medium">₡<span id="uiSubtotal">@Model.Subtotal.ToString("N2")</span></span>
                </div>
                <div class="flex justify-between text-slate-600 dark:text-slate-400">
                    <span>Impuestos (IVA)</span>
                    <span class="font-medium">₡<span id="uiIva">@Model.IVA.ToString("N2")</span></span>
                </div>
                <div class="flex justify-between text-slate-600 dark:text-slate-400">
                    <span>Costo de Envío</span>
                    <span class="font-medium text-emerald-500 uppercase text-xs font-bold tracking-wider pt-1" id="uiEnvioText">
                        @(Model.Envio == 0 ? "Gratis" : "₡" + Model.Envio.ToString("N2"))
                    </span>
                </div>
            </div>

            <!-- Total -->
            <div class="flex items-end justify-between border-t border-slate-100 dark:border-accent-dark pt-6 mt-6">
                <div>
                    <p class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Total a pagar</p>
                    <p class="text-4xl font-black text-primary">₡<span id="uiTotal">@Model.Total.ToString("N2")</span></p>
                </div>
            </div>
        </div>

        <!-- Botón Finalizar -->
        <div class="space-y-3 mt-8">
            <form asp-action="ConfirmarPedido" method="post">
                <input type="hidden" name="metodoEntrega" id="metodoEntregaHidden" value="Local" />
                <button type="submit" class="w-full relative overflow-hidden bg-primary hover:bg-primary/90 text-white py-4 rounded-xl font-bold text-xl shadow-lg shadow-primary/20 transition-all flex items-center justify-center gap-3">
                    Terminar Compra
                    <span class="material-symbols-outlined">payments</span>
                </button>
            </form>

            <p class="text-center text-[10px] text-slate-400 dark:text-slate-500 flex items-center justify-center gap-2 mt-4">
                <span class="material-symbols-outlined text-xs">verified_user</span>
                Pago encriptado bajo estándares TLS/SSL
            </p>
        </div>
    </aside>
</main>

@section Scripts {
    <script>
        // DOM Elements
        const methodLocal = document.getElementById('methodLocal');
        const methodDelivery = document.getElementById('methodDelivery');
        const localPickupDetails = document.getElementById('localPickupDetails');
        const deliveryDetails = document.getElementById('deliveryDetails');
        
        const payCard = document.getElementById('payCard');
        const payCash = document.getElementById('payCash');
        const creditCardWrapper = document.getElementById('creditCardWrapper');
        const cashWrapper = document.getElementById('cashWrapper');

        const metodoEntregaHidden = document.getElementById('metodoEntregaHidden');
        
        // C# Initialized
        const baseSubtotal = parseFloat('@Model.Subtotal'.replace(/,/g, ''));
        const baseIva = parseFloat('@Model.IVA'.replace(/,/g, ''));

        const uiEnvioText = document.getElementById('uiEnvioText');
        const uiTotal = document.getElementById('uiTotal');

        const formatCurrency = (val) => val.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});

        // Delivery Logic
        function updateDeliveryMethod() {
            let envioCost = 0;
            
            if (methodDelivery.checked) {
                envioCost = 2000.00;
                localPickupDetails.classList.add('hidden');
                deliveryDetails.classList.remove('hidden');
                metodoEntregaHidden.value = "Delivery";
                
                uiEnvioText.textContent = "₡" + formatCurrency(envioCost);
                uiEnvioText.classList.remove("text-emerald-500");
                uiEnvioText.classList.add("text-slate-500");
            } else {
                envioCost = 0.00;
                deliveryDetails.classList.add('hidden');
                localPickupDetails.classList.remove('hidden');
                metodoEntregaHidden.value = "Local";

                uiEnvioText.textContent = "Gratis";
                uiEnvioText.classList.remove("text-slate-500");
                uiEnvioText.classList.add("text-emerald-500");
            }

            const total = baseSubtotal + baseIva + envioCost;
            uiTotal.textContent = formatCurrency(total);
        }

        methodLocal.addEventListener('change', updateDeliveryMethod);
        methodDelivery.addEventListener('change', updateDeliveryMethod);

        // Payment Method Logic
        function updatePaymentMethod() {
            if (payCash.checked) {
                creditCardWrapper.classList.add('hidden');
                cashWrapper.classList.remove('hidden');
            } else {
                cashWrapper.classList.add('hidden');
                creditCardWrapper.classList.remove('hidden');
            }
        }

        payCard.addEventListener('change', updatePaymentMethod);
        payCash.addEventListener('change', updatePaymentMethod);

        // Init calculations
        updateDeliveryMethod();
        updatePaymentMethod();

        // Control Modals C#
        window.onload = function() {
            var success = '@ViewBag.OrderSuccess';
            if (success === 'True') {
                document.getElementById('orderSuccessModal').classList.remove('hidden');
                
                // Optional JS redirect timeout:
                setTimeout(() => {
                    window.location.href = '/Users/HomeUser';
                }, 3000);
            } else if (success === 'False') {
                document.getElementById('orderFailModal').classList.remove('hidden');
            }
        };
    </script>
}