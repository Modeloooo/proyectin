@model IEnumerable<ProyectoFinalGrupo3.Models.Pedido>
@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "Orders";

    var usuarios = ViewBag.Usuarios as List<ProyectoFinalGrupo3.Models.Usuarios> ?? new();
    var mesas = ViewBag.Mesas as List<ProyectoFinalGrupo3.Models.Mesa> ?? new();
    var productos = ViewBag.Productos as List<ProyectoFinalGrupo3.Models.Producto> ?? new();
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <div class="p-6 lg:p-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                    Mantenimiento de Pedidos
                </h2>
                <p class="text-slate-500 dark:text-primary/60 text-sm">
                    Gestiona los pedidos del restaurante y sus detalles.
                </p>
            </div>

            <button id="btnAgregar"
                    type="button"
                    class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-slate-100 px-6 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/30">
                <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
                <span>Añadir Nuevo Pedido</span>
            </button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-700 dark:text-green-400">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-700 dark:text-red-400">
                @TempData["Error"]
            </div>
        }

        <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-primary/5 border-b border-primary/20">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Pedido</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Cliente</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Tipo</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Mesa</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Fecha</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Estado</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-primary/10">
                        {
                            @foreach (var pedido in Model)
                            {
                                var usuario = usuarios.FirstOrDefault(u => u.Identificacion == pedido.IdUsuario);
                                var nombreUsuario = usuario?.NombreCompleto ?? pedido.IdUsuario ?? "Sin usuario";
                                var iniciales = "NA";

                                if (!string.IsNullOrWhiteSpace(nombreUsuario))
                                {
                                    var partes = nombreUsuario.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                    if (partes.Length == 1)
                                    {
                                        iniciales = partes[0].Substring(0, 1).ToUpper();
                                    }
                                    else
                                    {
                                        iniciales = $"{partes[0][0]}{partes[1][0]}".ToUpper();
                                    }
                                }

                                var badgeClass = "bg-amber-500/10 text-amber-500 border border-amber-500/30";
                                var dotClass = "bg-amber-500";

                                switch ((pedido.Estado ?? "").Trim().ToLower())
                                {
                                    case "entregado":
                                    case "servido":
                                    case "pagado":
                                        badgeClass = "bg-green-500/10 text-green-500 border border-green-500/30";
                                        dotClass = "bg-green-500";
                                        break;

                                    case "en preparación":
                                    case "en preparacion":
                                        badgeClass = "bg-blue-500/10 text-blue-500 border border-blue-500/30";
                                        dotClass = "bg-blue-500";
                                        break;

                                    case "cancelado":
                                        badgeClass = "bg-red-500/10 text-red-500 border border-red-500/30";
                                        dotClass = "bg-red-500";
                                        break;
                                }

                                <tr class="hover:bg-primary/5 transition-colors group">
                                    <td class="px-6 py-5">
                                        <span class="text-sm font-medium text-primary/60">#ORD-@pedido.CodigoPedido</span>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-2">
                                            <div class="size-7 rounded-full bg-slate-200 dark:bg-primary/20 flex items-center justify-center text-[10px] font-bold text-primary">
                                                @iniciales
                                            </div>
                                            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">
                                                @nombreUsuario
                                            </span>
                                        </div>
                                    </td>

                                    <td class="px-6 py-5">
                                        <span class="px-2 py-1 bg-slate-100 dark:bg-primary/10 text-slate-600 dark:text-primary/80 text-xs font-bold rounded">
                                            @(pedido.TipoPedido ?? "Sin tipo")
                                        </span>
                                    </td>

                                    <td class="px-6 py-5 text-sm text-slate-500 dark:text-primary/40">
                                        @(pedido.NumeroMesa != null ? $"Mesa {pedido.NumeroMesa}" : "No aplica")
                                    </td>

                                    <td class="px-6 py-5 text-sm text-slate-500 dark:text-primary/40">
                                        @(pedido.Fecha.ToString("dd/MM/yyyy HH:mm"))
                                    </td>

                                    <td class="px-6 py-5 text-center">
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                            <span class="size-1.5 rounded-full @dotClass"></span>
                                            @(pedido.Estado ?? "Pendiente")
                                        </span>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="flex justify-center gap-2">
                                            <button type="button"
                                                    class="btnVer p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all"
                                                    title="Ver"
                                                    data-id="@pedido.CodigoPedido"
                                                    data-usuario="@pedido.IdUsuario"
                                                    data-tipopedido="@pedido.TipoPedido"
                                                    data-numeromesa="@pedido.NumeroMesa"
                                                    data-estado="@pedido.Estado"
                                                    data-fecha="@pedido.Fecha.ToString("dd/MM/yyyy HH:mm")">
                                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                                            </button>

                                            <button type="button"
                                                    class="btnEditar p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all"
                                                    title="Editar"
                                                    data-id="@pedido.CodigoPedido"
                                                    data-usuario="@pedido.IdUsuario"
                                                    data-tipopedido="@pedido.TipoPedido"
                                                    data-numeromesa="@pedido.NumeroMesa"
                                                    data-estado="@pedido.Estado">
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>

                                            <button type="button"
                                                    class="btnEliminar p-2 rounded-lg hover:bg-red-500/10 text-slate-400 hover:text-red-500 transition-all"
                                                    title="Eliminar"
                                                    data-id="@pedido.CodigoPedido">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>

                                            <a asp-controller="Orders"
                                               asp-action="Detalles"
                                               asp-route-id="@pedido.CodigoPedido"
                                               class="p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all"
                                               title="Detalles">
                                                <span class="material-symbols-outlined text-[20px]">receipt_long</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
                <p class="text-xs text-slate-500 dark:text-primary/60">
                    Mostrando @Model.Count() pedido(s)
                </p>
            </div>
        </div>
    </div>
</main>

@await Html.PartialAsync("Partials/_ModalAgregar")
@await Html.PartialAsync("Partials/_ModalEliminar")
@await Html.PartialAsync("Partials/_ModalVer")

@section Scripts {
    <script src="~/js/orders.js"></script>
}