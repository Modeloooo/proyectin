@{
    var usuarios = ViewBag.Usuarios as List<ProyectoFinalGrupo3.Models.Usuarios> ?? new();
    var mesas = ViewBag.Mesas as List<ProyectoFinalGrupo3.Models.Mesa> ?? new();
    var productos = ViewBag.Productos as List<ProyectoFinalGrupo3.Models.Producto> ?? new();
}

<div id="modalAgregar" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
    <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-4xl rounded-2xl border border-primary/20 shadow-2xl overflow-hidden">
        <div class="px-8 py-6 border-b border-primary/10 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-black text-primary tracking-tight">Añadir Nuevo Pedido</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                    Registra un pedido nuevo con sus productos.
                </p>
            </div>
            <button id="btnCerrarModal" type="button" class="size-10 flex items-center justify-center rounded-full hover:bg-primary/10 text-slate-400 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <form asp-controller="Orders" asp-action="Crear" method="post">
            <div class="p-8 space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Usuario</label>
                        <select name="IdUsuario" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm outline-none" required>
                            <option value="">Seleccione un usuario</option>
                            @foreach (var u in usuarios)
                            {
                                <option value="@u.Identificacion">@u.NombreCompleto (@u.Identificacion)</option>
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Tipo de pedido</label>
                        <select name="TipoPedido" id="crearTipoPedido" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm outline-none" required>
                            <option value="">Seleccione</option>
                            <option value="Dine-in">Dine-in</option>
                            <option value="Delivery">Delivery</option>
                            <option value="Takeout">Takeout</option>
                        </select>
                    </div>

                    <div id="contenedorMesaCrear" class="space-y-2 md:col-span-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Mesa</label>
                        <select name="NumeroMesa" id="crearNumeroMesa" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm outline-none">
                            <option value="">Seleccione una mesa</option>
                            @foreach (var mesa in mesas)
                            {
                                <option value="@mesa.NumeroMesa">Mesa @mesa.NumeroMesa - @mesa.Estado</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">Productos del pedido</h3>

                        <button type="button"
                                id="btnAgregarFilaProducto"
                                class="px-4 py-2 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary font-bold text-sm transition-all">
                            Agregar producto
                        </button>
                    </div>

                    <div id="contenedorProductos" class="space-y-3">
                        <div class="fila-producto grid grid-cols-1 md:grid-cols-12 gap-3 items-end">
                            <div class="md:col-span-8 space-y-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Producto</label>
                                <select name="productoIds" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm outline-none" required>
                                    <option value="">Seleccione un producto</option>
                                    @foreach (var p in productos)
                                    {
                                        <option value="@p.CodigoProducto">@p.Nombre - ₡@((p.Precio).ToString("N2"))</option>
                                    }
                                </select>
                            </div>

                            <div class="md:col-span-2 space-y-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Cantidad</label>
                                <input type="number"
                                       name="cantidades"
                                       min="1"
                                       value="1"
                                       class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm outline-none"
                                       required />
                            </div>

                            <div class="md:col-span-2">
                                <button type="button"
                                        class="btnQuitarProducto w-full px-4 py-3 rounded-xl bg-red-500/10 hover:bg-red-500/20 text-red-500 font-bold text-sm transition-all">
                                    Quitar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="px-8 py-6 bg-slate-50 dark:bg-primary/5 border-t border-primary/10 flex items-center justify-end gap-4">
                <button id="btnCancelarModal"
                        type="button"
                        class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                    Cancelar
                </button>

                <button type="submit"
                        class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">check_circle</span>
                    Guardar Pedido
                </button>
            </div>
        </form>
    </div>
</div>