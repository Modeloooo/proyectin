<div id="modalVer" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
    <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-2xl rounded-2xl border border-primary/20 shadow-2xl overflow-hidden">
        <div class="px-8 py-6 border-b border-primary/10 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-black text-primary tracking-tight">Detalle del Pedido</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                    Información general del pedido seleccionado.
                </p>
            </div>
            <button id="cerrarVer" type="button" class="size-10 flex items-center justify-center rounded-full hover:bg-primary/10 text-slate-400 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Código de Pedido</p>
                    <p id="verCodigoPedido" class="text-lg font-black text-slate-900 dark:text-slate-100"></p>
                </div>

                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Usuario</p>
                    <p id="verIdUsuario" class="text-base font-bold text-slate-900 dark:text-slate-100"></p>
                </div>

                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Tipo de Pedido</p>
                    <p id="verTipoPedido" class="text-base font-bold text-slate-900 dark:text-slate-100"></p>
                </div>

                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Mesa</p>
                    <p id="verNumeroMesa" class="text-base font-bold text-slate-900 dark:text-slate-100"></p>
                </div>

                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Estado</p>
                    <p id="verEstado" class="text-base font-bold text-slate-900 dark:text-slate-100"></p>
                </div>

                <div class="bg-slate-100 dark:bg-primary/5 rounded-xl p-4 border border-primary/10">
                    <p class="text-xs uppercase font-bold tracking-wider text-slate-500 dark:text-slate-400 mb-2">Fecha</p>
                    <p id="verFecha" class="text-base font-bold text-slate-900 dark:text-slate-100"></p>
                </div>
            </div>
        </div>

        <div class="px-8 py-6 bg-slate-50 dark:bg-primary/5 border-t border-primary/10 flex items-center justify-end gap-4">
            <button id="btnCerrarVer"
                    type="button"
                    class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">check_circle</span>
                Cerrar
            </button>
        </div>
    </div>
</div>