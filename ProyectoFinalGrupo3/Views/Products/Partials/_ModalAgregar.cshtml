<div id="modalAgregar" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
    <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-2xl rounded-2xl border border-primary/20 shadow-2xl overflow-y-auto max-h-screen animate-in fade-in zoom-in duration-300">
        <!-- Modal Header -->
        <div class="px-8 py-6 border-b border-primary/10 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-black text-primary tracking-tight">Añadir Nuevo Producto</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Ingresa los detalles para el nuevo producto.</p>
            </div>
            <button id="btnCerrarModal" class="size-10 flex items-center justify-center rounded-full hover:bg-primary/10 text-slate-400 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <!-- Modal Body -->
        <div class="p-8">
            <form asp-action="Crear" asp-controller="Products" method="post" class="space-y-6">

                <div class="grid grid-cols-2 gap-6">
                    <!-- Código autogenerado -->
                    <div class="mb-4">
                        <label>Código del Producto</label>
                        <input name="CodigoProducto"
                               class="w-full bg-slate-200 dark:bg-primary/10 border border-primary/20 rounded-xl px-4 py-3 text-sm text-slate-500 cursor-not-allowed"
                               placeholder="Este campo se autogenera"
                               type="text"
                               readonly />
                    </div>
                    <!-- Nombre -->
                    <div class="mb-4">
                        <label>Nombre</label>
                        <input name="Nombre" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" placeholder="Ej: Filete Mignon" />
                    </div>

                    <!-- Categoría (select dinámico) -->
                    <div class="mb-4">
                        <label>Categoría</label>
                        <select name="CodigoCategoria" asp-items="ViewBag.Categorias"
                                class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                            <option value="">Seleccione una categoría</option>
                        </select>
                    </div>

                    <!-- Precio -->
                    <div class="mb-4">
                        <label>Precio</label>
                        <input name="Precio" type="number" step="0.01" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" placeholder="Ej: 42.00" />
                    </div>

                    <!-- Cantidad -->
                    <div class="mb-4">
                        <label>Cantidad</label>
                        <input name="Cantidad" type="number" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" placeholder="Ej: 10" />
                    </div>
                    <div class="mb-4">
                        <label>Requiere Empaque</label>
                        <select id="editEmpaque" name="RequiereEmpaque"
                                class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                            <option value="0">No</option>
                            <option value="1">Sí</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label>Costo Empaque</label>
                        <input id="editCostoEmpaque" name="CostoEmpaque" type="number" step="0.01"
                               class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                    </div>

                    <!-- Estado -->
                    <div class="mb-4">
                        <label>Estado</label>
                        <select id="editEstado" name="Estado"
                                class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                            <option value="1">Activo</option>
                            <option value="0">Inactivo</option>
                        </select>
                    </div>
                    <!-- Imagen -->
                    <div class="mb-4">
                        <label>URL Imagen</label>
                        <input name="UrlImagen" type="text" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" placeholder="Ej: https://..." />
                    </div>
                </div>
                <!-- Modal Actions -->
                <div class="px-8 py-6 bg-slate-50 dark:bg-primary/5 border-t border-primary/10 flex items-center justify-end gap-4">
                    <button type="button" id="btnCancelarModal" class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                        Cancelar
                    </button>
                    <button type="submit" class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">check_circle</span>
                        Guardar Producto
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
