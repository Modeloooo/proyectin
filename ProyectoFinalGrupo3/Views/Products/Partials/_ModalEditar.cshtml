<div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
    <div id="modalEditar" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
        <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-2xl rounded-2xl border border-primary/20 shadow-2xl overflow-hidden">

            <!-- Header -->
            <div class="px-8 py-6 border-b border-primary/10 flex justify-between">
                <h2 class="text-2xl font-black text-primary">Editar Producto</h2>
                <button id="cerrarEditar">X</button>
            </div>

            <!-- Body -->
            <div class="p-8">
                <form asp-action="Editar" asp-controller="Products" method="post">
                    <div class="grid grid-cols-2 gap-6">
                        <!-- Código (NO editable) -->
                        <div class="mb-4">
                            <label>Código</label>
                            <input id="editCodigoProducto" name="CodigoProducto" readonly
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm cursor-not-allowed" />
                        </div>

                        <!-- Nombre -->
                        <div class="mb-4">
                            <label>Nombre</label>
                            <input id="editNombre" name="Nombre"
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                        </div>

                        <!-- Categoría -->
                        <div class="mb-4">
                            <label>Categoría</label>
                            <select id="editCategoria" name="CodigoCategoria" asp-items="ViewBag.Categorias"
                                    class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                                <option value="">Seleccione una categoría</option>
                            </select>
                        </div>

                        <!-- Precio -->
                        <div class="mb-4">
                            <label>Precio</label>
                            <input id="editPrecio" name="Precio" type="number" step="0.01"
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                        </div>

                        <!-- Cantidad -->
                        <div class="mb-4">
                            <label>Cantidad</label>
                            <input id="editCantidad" name="Cantidad" type="number"
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                        </div>

                        <!-- Empaque -->
                        <div class="mb-4">
                            <label>Requiere Empaque</label>
                            <select id="editEmpaque" name="RequiereEmpaque"
                                    class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                                <option value="0">No</option>
                                <option value="1">Sí</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label>Costo Empaque</label>
                            <input id="editCostoEmpaque" name="CostoEmpaque" type="number" step="0.01"
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                        </div>

                        <!-- Estado -->
                        <div class="mb-4">
                            <label>Estado</label>
                            <select id="editEstado" name="Estado"
                                    class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm">
                                <option value="1">Activo</option>
                                <option value="0">Inactivo</option>
                            </select>
                        </div>

                        <!-- Imagen -->
                        <div class="mb-4">
                            <label>URL Imagen</label>
                            <input id="editUrlImagen" name="UrlImagen" type="text"
                                   class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm" />
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="flex justify-end gap-2">
                        <button type="button" id="cancelarEditar" class="bg-gray-400 px-4 py-2 rounded">Cancelar</button>
                        <button type="submit" class="bg-primary text-white px-4 py-2 rounded">Guardar</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
