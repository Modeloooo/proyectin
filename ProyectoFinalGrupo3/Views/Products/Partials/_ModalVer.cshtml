<div id="modalVer" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
    <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-xl rounded-2xl border border-primary/20 shadow-2xl">

        <!-- Header -->
        <div class="px-6 py-4 border-b border-primary/10 flex justify-between items-center">
            <h2 class="text-xl font-bold text-primary">Detalle de Producto</h2>
            <button id="cerrarVer">X</button>
        </div>

        <!-- Body -->
        <div class="p-6 space-y-4">
            <div class="grid grid-cols-2 gap-6">
                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Código</label>
                    <p id="verCodigoProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Nombre</label>
                    <p id="verNombreProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Categoría</label>
                    <p id="verCategoriaProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Precio</label>
                    <p id="verPrecioProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Cantidad</label>
                    <p id="verCantidadProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Requiere Empaque</label>
                    <p id="verEmpaqueProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Costo Empaque</label>
                    <p id="verCostoEmpaqueProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Estado</label>
                    <p id="verEstadoProducto" class="text-slate-500"></p>
                </div>

                <div>
                    <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Imagen</label>
                    <img id="verImagenProducto" class="w-32 h-32 object-cover rounded-lg border border-primary/20" />
                </div>
            </div>


        </div>

        <!-- Footer -->
        <div class="p-4 flex justify-end">
            <button id="cerrarVerBtn" class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">Cerrar</button>
        </div>

    </div>
</div>
