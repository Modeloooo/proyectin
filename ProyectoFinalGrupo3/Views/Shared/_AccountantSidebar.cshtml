}
<aside class="w-64 flex-shrink-0 bg-slate-100 dark:bg-black/40 border-r border-slate-200 dark:border-primary/10 flex flex-col">
    <div class="p-6 flex items-center gap-3">
        <div class="size-10 bg-primary rounded-full flex items-center justify-center text-white">
            <span class="material-symbols-outlined">restaurant</span>
        </div>
        <div class="flex flex-col">
            <h1 class="text-lg font-bold leading-none tracking-tight text-primary">Atelier 27</h1>
            <p class="text-xs text-slate-500 dark:text-primary/60 font-medium">Admin Panel</p>
        </div>
    </div>
    <nav class="flex-1 px-4 py-4 space-y-1 custom-scrollbar overflow-y-auto">
        <a onclick="document.location.href='@Url.Content("~/Orders/HistoryAccountantOrder/")'" class="flex items-center gap-3 px-4 py-3 rounded-lg @(ViewData["Title"]?.ToString() == "HistoryAccountantOrder" ? "bg-primary text-background-dark font-semibold" : "text-text-muted hover:bg-neutral-gold/20 hover:text-primary")">
            <span class="material-symbols-outlined">dashboard</span>
            <span>Historial De Compras</span>
        </a>
    </nav>
