@model List<Mesa>
@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "Tables";
}
<partial name="Partials/_ModalAgregar" model="Model" />
<partial name="Partials/_ModalEditar" model="Model" />
<partial name="Partials/_ModalEliminar" model="Model" />
<partial name="Partials/_ModalVer" model="Model" />
@if (TempData["Error"] != null)
{
    <div class="bg-red-500 text-white p-3 rounded mb-4">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="bg-green-500 text-white p-3 rounded mb-4">
        @TempData["Success"]
    </div>
}

<div class="p-6 lg:p-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">Mantenimiento de Mesas</h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">Gestiona las Mesas.</p>
        </div>
        <button id="btnAgregar" class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-slate-100 px-6 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/30">
            <span class="material-symbols-outlined">table_restaurant</span>
            <span>Añadir Nueva Mesa</span>
        </button>
    </div>
    <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-primary/5 border-b border-primary/20">
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Numero de Mesa</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Capacidad</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Estado</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-primary/10">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-primary/5 transition-colors group">

                            <!-- Código -->
                            <td class="px-6 py-5 text-sm font-medium text-primary/60">
                                T-@item.NumeroMesa
                            </td>

                            <!-- Capacidad -->
                            <td class="px-6 py-5 text-slate-600 dark:text-slate-400">
                                @item.Capacidad Personas
                            </td>

                            <!-- Estado -->
                            <td class="px-6 py-5 text-center">
                                @if (item.Estado == "Libre")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">
                                        <span class="size-1.5 rounded-full bg-emerald-500"></span>
                                        Libre
                                    </span>
                                }
                                else if (item.Estado == "Ocupada")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-rose-500/10 text-rose-500 border border-rose-500/20">
                                        <span class="size-1.5 rounded-full bg-rose-500 animate-pulse"></span>
                                        Ocupada
                                    </span>
                                }
                                else if (item.Estado == "Reservada")
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                                        <span class="size-1.5 rounded-full bg-primary"></span>
                                        Reservada
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-500/10 text-slate-500 border border-slate-500/20">
                                        <span class="size-1.5 rounded-full bg-slate-500"></span>
                                        @item.Estado
                                    </span>
                                }
                            </td>

                            <!-- Acciones -->
                            <td class="px-6 py-5">
                                <div class="flex justify-center gap-2">

                                    <!-- Ver -->
                                    <button class="btnVer p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all"
                                            data-id="@item.NumeroMesa"
                                            data-capacidad="@item.Capacidad"
                                            data-estado="@item.Estado">
                                        <span class="material-symbols-outlined text-[20px]">visibility</span>
                                    </button>

                                    <!-- Editar -->
                                    <button class="btnEditar p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary transition-all"
                                            data-id="@item.NumeroMesa"
                                            data-capacidad="@item.Capacidad"
                                            data-estado="@item.Estado">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </button>

                                    <!-- Eliminar -->
                                    <button class="btnEliminar p-2 rounded-lg hover:bg-red-500/10 text-slate-400 hover:text-red-500 transition-all"
                                            data-id="@item.NumeroMesa">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>

                                </div>
                            </td>

                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
            <p class="text-xs text-slate-500 dark:text-primary/60">Mostrando 7 de 24 mesas</p>
            <div class="flex gap-1">
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-primary hover:bg-primary hover:text-slate-100 transition-all cursor-not-allowed opacity-50">
                    <span class="material-symbols-outlined text-sm">chevron_left</span>
                </button>
                <button class="size-8 flex items-center justify-center rounded-lg bg-primary text-slate-100 font-bold text-xs">1</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-slate-500 hover:text-primary hover:bg-primary/10 transition-all font-bold text-xs">2</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-slate-500 hover:text-primary hover:bg-primary/10 transition-all font-bold text-xs">3</button>
                <button class="size-8 flex items-center justify-center rounded-lg border border-primary/20 text-primary hover:bg-primary hover:text-slate-100 transition-all">
                    <span class="material-symbols-outlined text-sm">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/mesas.js"></script>
}