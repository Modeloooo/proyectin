<!-- Modal Overlay -->
<div id="modalAgregar" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#0a0805]/80 backdrop-blur-sm hidden">
    <div class="bg-background-light dark:bg-[#1a160d] w-full max-w-2xl rounded-2xl border border-primary/20 shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
        <!-- Modal Header -->
        <div class="px-8 py-6 border-b border-primary/10 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-black text-primary tracking-tight">Añadir Nueva Mesa</h2>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Ingresa los detalles para la nueva mesa del restaurante.</p>
            </div>
            <button id="btnCerrarModal" class="size-10 flex items-center justify-center rounded-full hover:bg-primary/10 text-slate-400 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <!-- Modal Body -->
        <div class="p-8">
            <form asp-controller="Tables" asp-action="Crear" method="post" class="space-y-6">
                <div class="grid grid-cols-2 gap-6">
                    <!-- Name -->
                    <div class="col-span-2 md:col-span-1 space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Numero de Mesa</label>
                        <input name="NumeroMesa" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary transition-all outline-none" placeholder="Ej: 01" type="number" />
                    </div>
                    <!-- Name -->
                    <div class="col-span-2 md:col-span-1 space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Capacidad</label>
                        <input name="Capacidad" min="1" required class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary transition-all outline-none" placeholder="Ej: 01" type="number" />
                    </div>
                    <!-- Category -->
                    <div class="col-span-2 md:col-span-1 space-y-2">
                        <label class="text-sm font-bold text-slate-700 dark:text-slate-300 px-1">Categoría</label>
                        <select name="Estado" class="w-full bg-slate-100 dark:bg-primary/5 border border-primary/20 rounded-xl px-4 py-3 text-sm focus:ring-primary focus:border-primary transition-all outline-none appearance-none">
                            <option value="Libre">Libre</option>
                            <option value="Ocupada">Ocupada</option>
                            <option value="Reservada">Reservada</option>
                        </select>
                    </div>
                </div>
                <!-- Modal Actions -->
                <div id="btnCancelarModal" class="px-8 py-6 bg-slate-50 dark:bg-primary/5 border-t border-primary/10 flex items-center justify-end gap-4">
                    <button class="px-6 py-2.5 text-sm font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors">
                        Cancelar
                    </button>
                    <button class="px-8 py-2.5 bg-primary text-white rounded-xl font-bold text-sm shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">check_circle</span>
                        Guardar Mesa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
