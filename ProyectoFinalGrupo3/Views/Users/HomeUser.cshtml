@model ProyectoFinalGrupo3.Models.HomeUserViewModel;

@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "HomeUser";
}
<main class="h-screen overflow-y-auto bg-background-light dark:bg-background-dark">
    <div class="flex-1 p-8">
        <!-- Header -->
        <header class="flex justify-between items-center mb-10">
            <div class="flex flex-col gap-1">
                <h2 class="text-4xl font-black tracking-tight text-slate-900 dark:text-slate-100">Bienvenido</h2>
                <p class="text-slate-500 dark:text-primary/60">Disfruta de la mejor experiencia gastronómica hoy.</p>
            </div>
        </header>
        <!-- Module: Hacer Pedido -->
        <section class="mb-12">
            <div class="grid grid-cols-2 gap-6">
                <!-- Para Llevar Card -->
                <a href="/Orders/CreateUserOrder/" class="block">
                    <div class="group relative h-64 rounded-xl overflow-hidden cursor-pointer">
                        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/90 to-transparent z-10"></div>
                        <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" data-alt="Delicious gourmet burger with gold accents" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDqtg36FGNWfYubWpU63hOwk1CtNP65zV4vuPRMC3-F-fWoBgI25eS4V5ahTEp9we5fVPs3yaALFr0HBSDTghKwPco3BtJHURckxFnSYwJHyaXbiKMNi2gbEZUm0MEGLqCZpHXeMWYI9fA15SeOh6TFqW10XpODH54fopT87F3X-h5LWFnG4GOp3UWfWA5gNQd0s_r5FShlDh42fInhWmyJC--JQilInNUdh8qzV2URDtdiBat_tr4zvdxDVzOy_oTT6VGDt49TO5nG" />
                        <div class="absolute bottom-0 left-0 p-8 z-20">
                            <div class="bg-primary/20 backdrop-blur-md px-3 py-1 rounded-full w-fit mb-3 border border-primary/30">
                                <span class="text-primary text-xs font-bold uppercase tracking-widest">Takeaway</span>
                            </div>
                            <h4 class="text-3xl font-bold text-white mb-2">Para Llevar</h4>
                            <p class="text-slate-300 text-sm max-w-xs">Recoge tu pedido en 20 minutos sin esperas.</p>
                        </div>
                        <div class="absolute top-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity">
                            <div class="size-12 rounded-full bg-primary text-background-dark flex items-center justify-center">
                                <span class="material-symbols-outlined font-bold">arrow_forward</span>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Delivery Card -->
                <a href="/Orders/CreateUserOrder/" class="block">
                    <div class="group relative h-64 rounded-xl overflow-hidden cursor-pointer">
                        <div class="absolute inset-0 bg-gradient-to-t from-background-dark/90 to-transparent z-10"></div>
                        <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" data-alt="High-end plated steak with vegetables" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAi4IAXuERNwjX53ZgseBGNZgPMfrxHVTeLOwTeZYEyfRp6TZgYG-CyP5eLeRRWjRp0uehWVeywzhmuCwPc6b3ffoAesQSSxQHXtTEllAo3SFFLbY4Sh12nKJ36V8qL3bULoGNXUK4TSnjbh25yglpb9SLwMzLdNIsyxTLZNxwEyqtQb_HuKC2aNXLTAN_oGaXkN_e4nlK8kU8q59eE8mttotSP4C68FkxHGRUwsCahMkUxYE07wF4VuufOScyHaZGbzRUAQpOL3DMZ" />
                        <div class="absolute bottom-0 left-0 p-8 z-20">
                            <div class="bg-primary/20 backdrop-blur-md px-3 py-1 rounded-full w-fit mb-3 border border-primary/30">
                                <span class="text-primary text-xs font-bold uppercase tracking-widest">At Your Door</span>
                            </div>
                            <h4 class="text-3xl font-bold text-white mb-2">Delivery</h4>
                            <p class="text-slate-300 text-sm max-w-xs">Disfruta la alta cocina en la comodidad de tu hogar.</p>
                        </div>
                        <div class="absolute top-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity">
                            <div class="size-12 rounded-full bg-primary text-background-dark flex items-center justify-center">
                                <span class="material-symbols-outlined font-bold">delivery_dining</span>
                            </div>
                        </div>
                    </div>
                </a>

            </div>
        </section>
        <div class="grid grid-cols-3 gap-8">
            <!-- Module: Mis Compras (Table) -->
            <section class="col-span-2">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-2xl font-bold tracking-tight">Mis Compras</h3>
                    <span class="text-xs text-primary/60 font-bold uppercase tracking-widest">Últimos 30 días</span>
                </div>
                <div class="bg-primary/5 border border-primary/10 rounded-xl overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-primary/10">
                            <tr>
                                <th class="px-6 py-4 text-xs font-bold text-primary uppercase tracking-widest">ID Pedido</th>
                                <th class="px-6 py-4 text-xs font-bold text-primary uppercase tracking-widest">Fecha</th>
                                <th class="px-6 py-4 text-xs font-bold text-primary uppercase tracking-widest">Total</th>
                                <th class="px-6 py-4 text-xs font-bold text-primary uppercase tracking-widest text-right">Estado</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-primary/10">
                            @foreach (var pedido in Model.Pedidos)
                            {
                                <tr class="hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-4 font-mono text-sm">@pedido.CodigoPedido</td>
                                    <td class="px-6 py-4 text-sm opacity-80">@pedido.Fecha.ToString("dd MMM yyyy")</td>
                                    <td class="px-6 py-4 text-sm font-bold">$@pedido.Total.ToString("N2")</td>
                                    <td class="px-6 py-4 text-right">
                                        @if (pedido.Estado == "Pendiente")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-slate-500/20 text-slate-500 text-xs font-bold">
                                                <span class="size-1.5 rounded-full bg-slate-500"></span>
                                                Pendiente
                                            </span>
                                        }
                                        else if (pedido.Estado == "Preparación")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-orange-500/20 text-orange-400 text-xs font-bold">
                                                <span class="size-1.5 rounded-full bg-orange-400"></span>
                                                En preparación
                                            </span>
                                        }
                                        else if (pedido.Estado == "Servido")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/20 text-green-400 text-xs font-bold">
                                                <span class="size-1.5 rounded-full bg-green-400"></span>
                                                Entregado
                                            </span>
                                        }
                                        else if (pedido.Estado == "Cancelado")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-red-500/20 text-red-400 text-xs font-bold">
                                                <span class="size-1.5 rounded-full bg-red-400"></span>
                                                Cancelado
                                            </span>
                                        }
                                        else if (pedido.Estado == "Pagado")
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/20 text-green-400 text-xs font-bold">
                                                <span class="size-1.5 rounded-full bg-green-400"></span>
                                                Entregado
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </section>
            <!-- Module: Mi Perfil (Quick Update) -->
            <section class="col-span-1">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-2xl font-bold tracking-tight">Mi Perfil</h3>
                </div>
                <div class="bg-primary/5 border border-primary/10 rounded-xl p-6">
                    <form class="flex flex-col gap-5">
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-primary uppercase tracking-widest pl-1">Identificacion</label>
                            <input class="bg-background-dark/50 border border-primary/20 rounded-lg px-4 py-2 focus:ring-1 focus:ring-primary outline-none transition-all" 
                            type="tel" 
                            value="@Model.Usuario.Identificacion"
                            disabled />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-primary uppercase tracking-widest pl-1">Nombre Completo</label>
                            <input class="bg-background-dark/50 border border-primary/20 rounded-lg px-4 py-2 focus:ring-1 focus:ring-primary outline-none transition-all"
                                   type="text" 
                                   value="@Model.Usuario.NombreCompleto"
                                   disabled />
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-primary uppercase tracking-widest pl-1">Email</label>
                            <input class="bg-background-dark/50 border border-primary/20 rounded-lg px-4 py-2 focus:ring-1 focus:ring-primary outline-none transition-all" 
                                   type="email"
                                   value="@Model.Usuario.Correo" 
                                   disabled/>
                        </div>
                    </form>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</main>