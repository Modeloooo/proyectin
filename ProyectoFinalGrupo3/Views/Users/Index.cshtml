@model IEnumerable<ProyectoFinalGrupo3.Models.Usuarios>

@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "Users";
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <div class="p-6 lg:p-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div>
                <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                    Mantenimiento de Usuarios
                </h2>
                <p class="text-slate-500 dark:text-primary/60 text-sm">
                    Gestiona los accesos y roles de tu equipo de trabajo.
                </p>
            </div>

            <button id="btnAgregar"
                    type="button"
                    class="flex items-center gap-2 bg-primary hover:bg-primary/90 text-slate-100 px-6 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/30">
                <span class="material-symbols-outlined text-lg">person_add</span>
                <span>Añadir Nuevo Usuario</span>
            </button>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-700 dark:text-green-400">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-700 dark:text-red-400">
                @TempData["Error"]
            </div>
        }
        @if (TempData["ContrasenaGenerada"] != null)
        {
            <div class="alert alert-success">
                Contraseña generada: @TempData["ContrasenaGenerada"]
            </div>
        }

        <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-primary/5 border-b border-primary/20">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">ID</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Nombre</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Correo Electrónico</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Perfil</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-primary/10">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var usuario in Model)
                            {
                                var nombre = usuario.NombreCompleto ?? "Sin nombre";
                                var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                var iniciales = "NA";

                                if (partes.Length == 1)
                                {
                                    iniciales = partes[0].Substring(0, 1).ToUpper();
                                }
                                else if (partes.Length >= 2)
                                {
                                    iniciales = $"{partes[0][0]}{partes[1][0]}".ToUpper();
                                }

                                var badgeClass = "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 border border-slate-300 dark:border-slate-700";

                                switch ((usuario.Perfil ?? "").Trim().ToLower())
                                {
                                    case "administrador":
                                        badgeClass = "bg-primary/20 text-primary border border-primary/30";
                                        break;
                                    case "usuario":
                                        badgeClass = "bg-blue-500/10 text-blue-500 border border-blue-500/30";
                                        break;
                                }

                                <tr class="hover:bg-primary/5 transition-colors group">
                                    <td class="px-6 py-5 text-sm font-medium text-primary/60">
                                        #USR-@usuario.Identificacion
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-3">
                                            <div class="size-8 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-xs">
                                                @iniciales
                                            </div>
                                            <span class="text-sm font-semibold text-slate-900 dark:text-slate-100">
                                                @nombre
                                            </span>
                                        </div>
                                    </td>

                                    <td class="px-6 py-5 text-sm text-slate-500 dark:text-slate-400">
                                        @(usuario.Correo ?? "Sin correo")
                                    </td>

                                    <td class="px-6 py-5">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                            @(usuario.Perfil ?? "Sin perfil")
                                        </span>
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="flex justify-center gap-2">
                                            <button type="button" class="btnVer p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary"
                                                    data-identificacion="@usuario.Identificacion"
                                                    data-nombrecompleto="@usuario.NombreCompleto"
                                                    data-genero="@usuario.Genero"
                                                    data-correo="@usuario.Correo"
                                                    data-tipotarjeta="@usuario.TipoTarjeta"
                                                    data-numerotarjeta="@usuario.NumeroTarjeta"
                                                    data-dinerodisponible="@usuario.DineroDisponible"
                                                    data-perfil="@usuario.Perfil">
                                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                                            </button>

                                            <button type="button" class="btnEditar p-2 rounded-lg hover:bg-primary/20 text-slate-400 hover:text-primary"
                                                    data-identificacion="@usuario.Identificacion"
                                                    data-nombrecompleto="@usuario.NombreCompleto"
                                                    data-genero="@usuario.Genero"
                                                    data-correo="@usuario.Correo"
                                                    data-tipotarjeta="@usuario.TipoTarjeta"
                                                    data-numerotarjeta="@usuario.NumeroTarjeta"
                                                    data-perfil="@usuario.Perfil">
                                                <span class="material-symbols-outlined text-[20px]">edit</span>
                                            </button>

                                            <button type="button" class="btnEliminar p-2 rounded-lg hover:bg-red-500/10 text-slate-400 hover:text-red-500"
                                                    data-id="@usuario.Identificacion">
                                                <span class="material-symbols-outlined text-[20px]">delete</span>
                                            </button>
                                            <form asp-action="ResetearContrasena" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@usuario.Identificacion" />
                                                <button type="submit"
                                                        class="p-2 rounded-lg hover:bg-yellow-500/10 text-slate-400 hover:text-yellow-500 transition-all"
                                                        title="Resetear contraseña"
                                                        onclick="return confirm('¿Resetear contraseña de @usuario.NombreCompleto?')">
                                                    <span class="material-symbols-outlined text-[20px]">restart_alt</span>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-slate-500">
                                    No hay usuarios registrados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
                <p class="text-xs text-slate-500">
                    Mostrando @Model.Count() usuario(s) registrados
                </p>
            </div>
        </div>
    </div>
</main>

@await Html.PartialAsync("Partials/_ModalAgregar")
@await Html.PartialAsync("Partials/_ModalEditar")
@await Html.PartialAsync("Partials/_ModalEliminar")
@await Html.PartialAsync("Partials/_ModalVer")

<!-- 🔥 MODAL CONTRASEÑA -->
@if (TempData["ContrasenaGenerada"] != null)
{
    <div class="modal fade" id="modalContrasena" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Usuario Creado</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <p>Usuario: <strong>@TempData["UsuarioCreado"]</strong></p>
                    <p>Contraseña generada:</p>

                    <div class="input-group mb-3">
                        <input type="text" id="txtContrasena" class="form-control text-center fw-bold"
                               value="@TempData["ContrasenaGenerada"]" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="copiarContrasena()">
                            📋 Copiar
                        </button>
                    </div>

                    <p class="text-warning small">⚠️ Guarde esta contraseña. No se mostrará nuevamente.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Aceptar</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/users.js"></script>

    @if (TempData["ContrasenaGenerada"] != null)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var modal = new bootstrap.Modal(document.getElementById('modalContrasena'));
                modal.show();
            });

            function copiarContrasena() {
                var input = document.getElementById('txtContrasena');
                input.select();
                input.setSelectionRange(0, 99999);
                navigator.clipboard.writeText(input.value);
                alert('Contraseña copiada');
            }
        </script>
    }
}