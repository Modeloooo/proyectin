@model IEnumerable<ProyectoFinalGrupo3.Models.Pedido>

@{
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
    ViewData["Title"] = "MisPedidos";
}

<main class="flex-1 flex flex-col min-w-0 overflow-y-auto">
    <div class="p-6 lg:p-10">
        <div class="mb-8">
            <h2 class="text-slate-900 dark:text-slate-100 text-3xl font-black tracking-tight mb-1">
                Mis Pedidos
            </h2>
            <p class="text-slate-500 dark:text-primary/60 text-sm">
                Historial de pedidos que has creado
            </p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-700 dark:text-green-400">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-700 dark:text-red-400">
                @TempData["Error"]
            </div>
        }

        <div class="bg-background-light dark:bg-background-dark border border-primary/20 rounded-xl shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-primary/5 border-b border-primary/20">
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80"># Pedido</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Mesa</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Fecha</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Estado</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80">Total</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-primary/80 text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-primary/10">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var pedido in Model)
                            {
                                var estadoClass = "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300";
                                switch ((pedido.Estado ?? "").Trim().ToLower())
                                {
                                    case "pendiente":
                                        estadoClass = "bg-yellow-500/10 text-yellow-500 border border-yellow-500/30";
                                        break;
                                    case "preparación":
                                    case "preparacion":
                                        estadoClass = "bg-blue-500/10 text-blue-500 border border-blue-500/30";
                                        break;
                                    case "servido":
                                        estadoClass = "bg-green-500/10 text-green-500 border border-green-500/30";
                                        break;
                                    case "cancelado":
                                        estadoClass = "bg-red-500/10 text-red-500 border border-red-500/30";
                                        break;
                                }

                                <tr class="hover:bg-primary/5 transition-colors">
                                    <td class="px-6 py-5 text-sm font-medium text-primary">
                                        #@pedido.CodigoPedido
                                    </td>
                                    <td class="px-6 py-5 text-sm text-slate-500 dark:text-slate-400">
                                        @(pedido.NumeroMesaNavigation != null ? $"Mesa {pedido.NumeroMesa}" : "Delivery")
                                    </td>
                                    <td class="px-6 py-5 text-sm text-slate-500 dark:text-slate-400">
                                        @pedido.Fecha.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @estadoClass">
                                            @pedido.Estado
                                        </span>
                                    </td>
                                    <td class="px-6 py-5 text-sm font-bold text-primary">
                                        ₡@pedido.Total.ToString("N2")
                                    </td>
                                    <td class="px-6 py-5 text-center">
                                        <a asp-action="DetallePedido" asp-route-id="@pedido.CodigoPedido"
                                               class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors text-sm">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                            Ver
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-10 text-center text-slate-500">
                                    No has creado ningún pedido aún.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="flex items-center justify-between p-4 border-t border-primary/20 bg-primary/5">
                <p class="text-xs text-slate-500">
                    Mostrando @(Model?.Count() ?? 0) pedido(s)
                </p>
                <a asp-action="Index" class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-bold hover:bg-primary/90 transition-colors">
                    + Nuevo Pedido
                </a>
            </div>
        </div>
    </div>
</main>